      ],
      "webhookId": "YOUR_WEBHOOK_PATH"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"model\": \"llama-3.3-70b-versatile\", \"max_tokens\": 10, \"messages\": [{\"role\": \"system\", \"content\": \"You are a sentiment classifier. Respond with exactly one word: Positive, Negative, or Neutral.\"}, {\"role\": \"user\", \"content\": {{ JSON.stringify($json.body.text) }}}] }",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "groq-http-sentiment",
      "name": "HTTP Request - Groq Sentiment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        464,
        352
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_GROQ_CREDENTIAL_ID",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "sentiment",
              "value": "={{ $json.choices[0].message.content.trim().replace(/[^a-zA-Z]/g, '') }}",
              "type": "string"
            },
            {
              "name": "original_text",
              "value": "={{ $('Webhook').item.json.body.text }}",
              "type": "string"
            },
            {
              "name": "timestamp",
              "value": "={{ $now }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node-3",
      "name": "Set Node â€” Prepare Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [
        688,
        352
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://httpbin.org/post",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"tag\": \"positive-sentiment\",\n  \"text\": \"{{ $json.original_text }}\",\n  \"timestamp\": \"{{ $json.timestamp }}\"\n}",
        "options": {}
      },
      "id": "node-5",
      "name": "HTTP POST â€” CRM Tag",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1360,
        560
      ]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "={{ $('Code - Build Alert').item.json.tg_message }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "node-6",
      "name": "Telegram â€” Negative Alert",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1584,
        240
      ],
      "webhookId": "YOUR_WEBHOOK_ID",
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram account 5"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.sentiment_log (text, sentiment, created_at)\nVALUES ($1, $2, $3::timestamptz)\nRETURNING id, sentiment, text, created_at;",
        "options": {
          "queryReplacement": "={{ [$json.original_text, $json.sentiment, $json.timestamp] }}"
        }
      },
      "id": "node-7",
      "name": "PostgreSQL â€” DB Log",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        912,
        352
      ],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\"status\":\"processed\",\"workflow\":\"WF3-sentiment\"}",
        "options": {}
      },
      "id": "node-8",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1808,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.sentiment }}",
              "operation": "equal",
              "value2": "Negative"
            }
          ]
        }
      },
      "id": "if-neg",
      "name": "IF — Is Negative?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1136,
        336
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.sentiment }}",
              "operation": "equal",
              "value2": "Positive"
            }
          ]
        }
      },
      "id": "if-pos",
      "name": "IF — Is Positive?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1136,
        560
      ]
    },
    {
      "parameters": {
        "jsCode": "const s   = $json.sentiment || 'Unknown';\nconst txt = $json.text || '(no text)';\nconst ts  = ($json.created_at || '').substring(0, 19).replace('T', ' ');\nconst msg = `🚨 *Negative Sentiment Detected!*\n\n*Text:* ${txt}\n*Sentiment:* ${s}\n*Time:* ${ts}\n\nPlease review and respond.`;\nreturn [{json: {sentiment: s, text: txt, created_at: ts, tg_message: msg}}];"
      },
