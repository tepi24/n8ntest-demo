    {
      "parameters": {
        "jsCode": "const allPapers = $('Code Node - Deduplicate by ID').all();\nconst count = allPapers.length;\n\nconst topPapers = allPapers.slice(0, 5).map((p, i) => {\n  const title    = (p.json.title    || '(no title)').substring(0, 100);\n  const source   =  p.json.source   || '?';\n  const date     = (p.json.published_date || 'n/a').substring(0, 10);\n  const abstract = (p.json.abstract || '').trim().substring(0, 120);\n  const snippet  = abstract ? abstract + '...' : '';\n  const url      =  p.json.url || '';\n  return `${i+1}. *${title}*\n   ${source} | ${date}\n   ${snippet}\n   ${url}`.trim();\n}).join('\\n\\n');\n\n\nconst digest = `Daily Research Digest - ${new Date().toDateString()}\n\nPapers collected: ${count}\n\nTop picks:\n\n${topPapers}\n\nSources: arXiv, Semantic Scholar, PubMed`;\n\nreturn [{json: {count, digest}}];"
      },
