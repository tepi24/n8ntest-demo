          "query": "CREATE TABLE IF NOT EXISTS public.research_papers (paper_id TEXT PRIMARY KEY, title TEXT, abstract TEXT, authors TEXT, published_date TEXT, source TEXT, url TEXT, created_at TIMESTAMPTZ DEFAULT NOW());\nCREATE TABLE IF NOT EXISTS public.paper_embeddings (paper_id TEXT PRIMARY KEY, embedding TEXT, created_at TIMESTAMPTZ DEFAULT NOW());\nCREATE TABLE IF NOT EXISTS public.collection_watermark (id SERIAL PRIMARY KEY, last_run TIMESTAMPTZ, last_paper_id TEXT);\nINSERT INTO public.collection_watermark (last_run, last_paper_id) SELECT NOW(), NULL WHERE NOT EXISTS (SELECT 1 FROM public.collection_watermark);\nINSERT INTO public.research_papers (paper_id, title, abstract, authors, published_date, source, url, created_at) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW()) ON CONFLICT (paper_id) DO NOTHING;",
