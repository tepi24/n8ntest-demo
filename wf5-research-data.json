    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE public.collection_watermark SET last_run = NOW(), last_paper_id = $1 WHERE id = 1;",
        "options": {
          "queryReplacement": "={{ [$('Code Node - Deduplicate by ID').last().json.paper_id] }}"
        }
      },
      "id": "node-16",
      "name": "PostgreSQL - Update watermark",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        2032,
        448
      ],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
