    {
      "parameters": {
        "url": "=https://export.arxiv.org/api/query?search_query=cat:cs.AI&start={{ $json.offset || 0 }}&max_results=100",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "User-Agent",
              "value": "ResearchBot/1.0"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "node-2",
      "name": "HTTP Request - arXiv API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1024,
        128
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const body = item.json.data || \"\";\n  const entries = body.match(/<entry>[\\s\\S]*?<\\/entry>/g) || [];\n  for (const entry of entries) {\n    const id = (entry.match(/<id>(.*?)<\\/id>/) || [])[1] || \"\";\n    const title = (entry.match(/<title>([\\s\\S]*?)<\\/title>/) || [])[1] || \"\";\n    const summary = (entry.match(/<summary>([\\s\\S]*?)<\\/summary>/) || [])[1] || \"\";\n    const published = (entry.match(/<published>(.*?)<\\/published>/) || [])[1] || \"\";\n    const authors = [...entry.matchAll(/<name>(.*?)<\\/name>/g)].map(m => m[1]).join(\", \");\n    results.push({json: {paper_id: id.split(\"/abs/\").pop() || id,\n      title: title.trim().replace(/\\s+/g, \" \"),\n      abstract: summary.trim().replace(/\\s+/g, \" \"),\n      authors, published_date: published, source: \"arxiv\", url: id.trim()}});\n  }\n}\nreturn results;"
      },
      "id": "node-3",
      "name": "Code Node - Parse arXiv",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        128
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "https://api.semanticscholar.org/graph/v1/paper/search?query=artificial+intelligence&fields=paperId,title,abstract,authors,year,externalIds&limit=100",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key"
            }
          ]
        },
        "options": {}
      },
      "id": "node-6",
      "name": "HTTP Request - Semantic Scholar",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        912,
        416
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const papers = item.json.data || [];\n  for (const paper of papers) {\n    results.push({json: {paper_id: paper.paperId || \"\",\n      title: paper.title || \"\", abstract: paper.abstract || \"\",\n      authors: (paper.authors || []).map(a => a.name).join(\", \"),\n      published_date: paper.year ? String(paper.year) + \"-01-01\" : \"\",\n      source: \"semantic_scholar\",\n      url: \"https://www.semanticscholar.org/paper/\" + paper.paperId}});\n  }\n}\nreturn results;"
      },
      "id": "node-7",
      "name": "Code Node - Parse Semantic Scholar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        416
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&term=artificial+intelligence&retmax=100&retmode=json",
        "options": {}
      },
      "id": "node-8",
      "name": "HTTP Request - PubMed API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        912,
        608
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const ids = (item.json.esearchresult || {}).idlist || [];\n  for (const pmid of ids) {\n    results.push({json: {paper_id: \"pubmed_\" + pmid,\n      title: \"\", abstract: \"\", authors: \"\", published_date: \"\",\n      source: \"pubmed\",\n      url: \"https://pubmed.ncbi.nlm.nih.gov/\" + pmid + \"/\", pmid}});\n  }\n}\nreturn results;"
      },
      "id": "node-9",
      "name": "Code Node - Parse PubMed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        608
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {},
      "id": "node-10",
      "name": "Merge Node - Combine all sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1360,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seen = new Set();\nconst unique = [];\nfor (const item of items) {\n  const key = item.json.paper_id || (item.json.title || \"\").toLowerCase().trim();\n  if (key && !seen.has(key)) { seen.add(key); unique.push(item); }\n}\nreturn unique;"
      },
      "id": "node-11",
      "name": "Code Node - Deduplicate by ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1584,
        352
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "CREATE TABLE IF NOT EXISTS public.research_papers (paper_id TEXT PRIMARY KEY, title TEXT, abstract TEXT, authors TEXT, published_date TEXT, source TEXT, url TEXT, created_at TIMESTAMPTZ DEFAULT NOW());\nCREATE TABLE IF NOT EXISTS public.paper_embeddings (paper_id TEXT PRIMARY KEY, embedding TEXT, created_at TIMESTAMPTZ DEFAULT NOW());\nCREATE TABLE IF NOT EXISTS public.collection_watermark (id SERIAL PRIMARY KEY, last_run TIMESTAMPTZ, last_paper_id TEXT);\nINSERT INTO public.collection_watermark (last_run, last_paper_id) SELECT NOW(), NULL WHERE NOT EXISTS (SELECT 1 FROM public.collection_watermark);\nINSERT INTO public.research_papers (paper_id, title, abstract, authors, published_date, source, url, created_at) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW()) ON CONFLICT (paper_id) DO NOTHING;",
        "options": {
          "queryReplacement": "={{ [$json.paper_id, $json.title, $json.abstract, $json.authors, $json.published_date, $json.source, $json.url] }}"
        }
      },
      "id": "node-12",
      "name": "PostgreSQL - Upsert ON CONFLICT",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1808,
        352
      ],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map(item => ({json: {\n  paper_id: item.json.paper_id,\n  title: item.json.title,\n  abstract: item.json.abstract,\n  embed_input: (\"Title: \" + item.json.title + \"\\n\\nAbstract: \" + item.json.abstract).substring(0, 8000)\n}}));"
      },
      "id": "node-13",
      "name": "Code Node - Build Embed payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2032,
        256
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.jina.ai/v1/embeddings",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_JINA_API_KEY-ZCL3e9R_15V0v8XCJFtLpA"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"model\": \"jina-embeddings-v3\", \"input\": {{ JSON.stringify(Array.isArray($json.embed_input) ? $json.embed_input : [$json.embed_input]) }}, \"dimensions\": 512 }",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 30000
        }
      },
      "id": "node-14",
      "name": "HTTP Request - Embed abstracts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2256,
        256
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.paper_embeddings (paper_id, embedding, created_at) VALUES ($1, $2, NOW()) ON CONFLICT (paper_id) DO UPDATE SET embedding = EXCLUDED.embedding;",
        "options": {
          "queryReplacement": "=={{ [$('Code Node - Build Embed payload').item.json.paper_id, JSON.stringify($json.data[0].embedding)] }}\n"
        }
      },
      "id": "node-15",
      "name": "PostgreSQL - Store vector embedding",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        2480,
        256
      ],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
